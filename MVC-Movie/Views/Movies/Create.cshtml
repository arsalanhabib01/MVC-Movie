@model MVC_Movie.Models.Movie

@{
	Layout = "_FullscreenLayout";
    ViewData["Title"] = "Create";
}

<h1 class="fw-bold text-center mb-4 text-white">
	<i class="bi bi-film me-2 text-info"></i>
	Add Movie
</h1>

<div class="row justify-content-center">
	<div class="col-lg-8 col-xl-7">

		<div class="card shadow-lg border-0 rounded-4">
			<div class="card-body p-4 p-md-5">

				<form asp-action="Create" enctype="multipart/form-data">
					<input type="hidden" asp-for="Id" />
					<input type="hidden" asp-for="UserId" />

					<div asp-validation-summary="ModelOnly" class="text-danger"></div>

					<div class="mb-3">
						<label asp-for="Title" class="control-label"></label>
						<input asp-for="Title" class="form-control" />
						<span asp-validation-for="Title" class="text-danger"></span>
					</div>

					<div class="mb-3">
						<label asp-for="ReleaseDate" class="control-label"></label>
						<input asp-for="ReleaseDate" class="form-control" type="date" />
						<span asp-validation-for="ReleaseDate" class="text-danger"></span>
					</div>

					<div class="mb-3">
						<label asp-for="Genre" class="control-label"></label>
						<input asp-for="Genre" class="form-control" />
						<span asp-validation-for="Genre" class="text-danger"></span>
					</div>

					<div class="mb-3">
						<label asp-for="Description" class="control-label"></label>
						<input asp-for="Description" class="form-control" />
						<span asp-validation-for="Description" class="text-danger"></span>
					</div>

					<div class="mb-3">
						<label asp-for="Rating"></label>
						<input asp-for="Rating" type="number" class="form-control" step="0.1" />
						<span asp-validation-for="Rating" class="text-danger"></span>
					</div>

					<div class="mb-4">
						<label asp-for="FileForm" class="form-label"></label>
						<input asp-for="FileForm" type="file" class="form-control"
							   onchange="previewImage(event)" />
						<span asp-validation-for="FileForm" class="text-danger"></span>
					</div>

					<div id="preview-container" class="mb-4 text-center" style="display:none;">
						<label class="form-label fw-semibold d-block">Selected Image</label>
						<img id="preview-image"
							 class="img-thumbnail shadow-sm"
							 style="max-width:150px;" />
					</div>

					<div class="form-group d-flex justify-content-between mt-3">
						<button type="submit" class="btn btn-primary px-4">
							<i class="bi bi-plus-circle me-1"></i> Add Movie
						</button>
						<a class="btn btn-outline-secondary px-4" asp-action="Index">
							@* <i class="fa fa-arrow-left me-1"></i> *@
							Back
						</a>
					</div>
				</form>

			</<div>
		</div>
	</div>
</div>


@section Scripts {
    <script>
        function previewImage(event) {
            // Get the file input element and the preview elements
            // from the event target
            // event.target is the file input
            const input = event.target;
            // Get the preview container and image elements
            const previewContainer = document.getElementById("preview-container");
            const previewImage = document.getElementById("preview-image");

            // Check if a file is selected
            // input.files is the FileList object
            // input.files[0] is the first selected file
            if (input.files && input.files[0]) {
                // Create a FileReader to read the file
                const reader = new FileReader();
                // When the file is read, set the preview image source
                // and make the preview container visible
                reader.onload = function(e) {
                    // Set the preview image source to the file data
                    previewImage.src = e.target.result;
                    // Show the preview container
                    // "block" to make it visible"
                    previewContainer.style.display = "block";
                };
                // Read the file as a Data URL (base64)
                reader.readAsDataURL(input.files[0]);
            } else {
                // No file selected, hide the preview container
                // "none" to hide it
                previewContainer.style.display = "none";
                // Clear the preview image source
                previewImage.src = "";
            }
        }
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
