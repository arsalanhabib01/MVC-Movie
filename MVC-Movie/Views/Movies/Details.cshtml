@model MVC_Movie.Models.Movie
@using System.Globalization

@{
    Layout = "_FullscreenLayout";
    ViewData["Title"] = "Details";
}

<div class="row bg-white rounded-3 shadow-lg p-4 mt-4">

	<!-- LEFT: IMAGE -->
	<div class="col-md-4 position-relative text-center mb-4 mb-md-0">

		<img src="@Url.Content($"~/images/{Model.FileName}")"
			 class="img-fluid rounded border"
			 style="height:450px; width:100%; object-fit:cover;" />

		<!-- RATING BADGE -->
		<div class="position-absolute top-0 start-0 mt-2 ms-3 px-2 py-1 rounded"
			 style="background:rgba(0,0,0,0.7);">
			<span>⭐</span>
			<strong class="text-warning">
				@Model.Rating.ToString("0.0", CultureInfo.InvariantCulture)
			</strong>
		</div>
	</div>

	<!-- RIGHT: DETAILS -->
	<div class="col-md-8">

		<div class="d-flex justify-content-between align-items-center">

			<div class="d-flex align-items-center border-start border-4 border-primary ps-3">
				<div class="bg-light rounded-circle p-2 shadow-sm me-3">
					<i class="fa-solid fa-clapperboard text-primary fs-5"></i>
				</div>
				<div>
					<h2 class="fw-bold mb-0 text-uppercase">
						@Model.Title
					</h2>
					<small class="text-muted">Movie Details</small>
				</div>
			</div>

			<div class="d-flex align-items-center gap-2 mb-2">

				@if (User.Identity != null && User.Identity.IsAuthenticated)
				{
					<!-- COMMENT Button trigger modal -->
					<button type="button" title="Add Comment"
							class="btn btn-light p-2 favorite-icon m-0"
							data-bs-toggle="modal"
							data-bs-target="#commentModal">
						<i class="fa-regular fa-message fs-4"></i>
					</button>
				}

				<!-- Comment Modal-->
				<div class="modal fade" id="commentModal" tabindex="-1">
					<div class="modal-dialog modal-dialog-centered">
						<div class="modal-content">

							<div class="modal-header">
								<h5 class="modal-title text-muted w-100 text-center">
									Add Comment
								</h5>
								<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
							</div>

							<div class="modal-body">

								<form asp-controller="MovieComments" asp-action="AddComment"
									  asp-route-id="@Model.Id" method="post">

									<input type="hidden" name="movieId" value="@Model.Id" />

									<div class="form-group">
										<label>Your Comment</label>
										<textarea name="commentText"
											rows="3"
											class="form-control"
											placeholder="Write your comment..."
											required></textarea>
									</div>

									<div class="modal-footer">
										<button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
											Cancel
										</button>
										<button type="submit" class="btn btn-primary">
											Submit
										</button>
									</div>
								</form>
							</div>
						</div>
					</div>
				</div>

				@if (User.Identity != null && User.Identity.IsAuthenticated)
				{
					<!-- WATCHLIST For All Users -->
					@if (ViewBag.isInWatchList)
					{
						<i class="fa-solid fa-bookmark text-secondary opacity-50 ms-2 me-2 fs-4"
						   title="In Watchlist"
						   aria-label="In Watchlist"></i>
					}
					else
					{
						<div id="watchlistContainer">
							<form id="watchlistForm"
								  asp-controller="WatchLists"
								  asp-action="Add"
								  asp-route-movieId="@Model.Id"
								  method="post" class="m-0">

								<button type="submit" class="btn btn-light p-2 favorite-icon">
									<i class="fa-regular fa-bookmark fs-4"
									   title="Add to Watchlist"
									   aria-label="Add to Watchlist"></i>
								</button>
							</form>
						</div>

						<!-- WatchList Modal -->
						<div class="modal fade" id="watchlistModal" tabindex="-1">
							<div class="modal-dialog modal-dialog-centered">
								<div class="modal-content">
									<div class="modal-body text-center">
										<h5 id="watchlistMessage">Added to Watchlist!</h5>
									</div>
								</div>
							</div>
						</div>
					}
				}

				<a class="btn btn-light p-1 ms-1 close-icon" asp-action="Index">
					<i class="fa fa-times fs-2"></i>
				</a>
			</div>
		</div>

		<p class="mt-4">
			<strong class="text-muted">Genre:</strong>
			@foreach (var genre in Model.Genre.Split(','))
			{
				<span class="badge rounded-pill bg-primary bg-opacity-75 ms-1">
					@genre.Trim()
				</span>
			}
		</p>

		<!-- Movie Actors -->
		@if (ViewBag.ActorsMovie != null && ViewBag.ActorsMovie.Count > 0)
		{
			<div class="d-flex flex-wrap">
				<strong class="text-muted me-2 mt-1">Cast:</strong>
				@foreach (var actor in ViewBag.ActorsMovie)
				{
					<a asp-controller="MovieActors"
					   asp-action="ActorDetails"
					   asp-route-id="@actor.Id"
					   class="d-flex align-items-center bg-white border rounded-pill
							px-2 py-1 me-2 mb-2 shadow-sm text-decoration-none
							text-dark cast-item">

						<i class="fa-solid fa-masks-theater text-warning me-2"></i>
						<span>@actor.FullName</span>
					</a>
				}
			</div>
		}

		<p>
			<strong class="text-muted">Release Date:</strong>
			<i class="bi bi-calendar-event ms-1 me-1"></i>
			@Model.ReleaseDate.ToString("MMM dd, yyyy")
		</p>

		<p class="alert alert-info mb-4" style="text-align: justify;">
			<strong>Story Line: <i class="fa-solid fa-pen me-1"></i></strong>
			<br />
			<span class="">@Model.Description</span>
		</p>

		<div class="d-flex mb-4">
			<!-- SELECT LANGUAGE -->
			<select id="selectLanguage" class="form-select" style="max-width: 200px">
				<option value="">Choose Language</option>
				<option value="English">English</option>
				<option value="Swedish">Swedish</option>
				<option value="Norwegian">Norwegian</option>
			</select>

			<!-- SELECT Purchase Type -->
			<select id="purchaseType" class="form-select ms-3" style="max-width: 220px" disabled>
				<option value="">Choose Purchase Type</option>
				<option value="Buy">Buy Movie</option>
				<option value="Rent">Rent Movie</option>
			</select>
		</div>

		@if (User.IsInRole("Administrator"))
		{
			<div class="float-end">
				<a class="btn btn-warning me-1"
				   title="Film Editing"
				   asp-action="Edit" asp-route-id="@Model.Id">
					<i class="fa fa-pencil text-white"></i>
				</a>

@* 				<a class="btn btn-danger"
				   asp-action="Delete" asp-route-id="@Model.Id">
					<i class="fa fa-trash"></i>
				</a> *@


				<!-- Button trigger modal -->
				<button type="button" title="Delete Record"
						class="btn btn-danger"
						data-bs-toggle="modal"
						data-bs-target="#deleteModal">
					<i class="fa fa-trash"></i>
				</button>

			</div>
		}

		<!-- Deletion Modal-->
		<div class="modal fade" id="deleteModal" tabindex="-1">
			<div class="modal-dialog modal-dialog-centered">
				<div class="modal-content">

					<div class="modal-header">
						<h5 class="modal-title text-muted me-2">
							<i class="fa fa-trash text-danger"></i>
							Confirm Deletion
						</h5>
						<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
					</div>

					<div class="modal-body">
						<i class="fa fa-triangle-exclamation me-1"></i>
						Please confirm that you want to delete the movie
						<span class="text-uppercase fw-bold text-muted">@Model.Title ?</span>
					</div>

					<div class="modal-footer">
						<button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
							Cancel
						</button>

						<form asp-action="Delete" asp-route-id="@Model.Id" method="post">
							<button type="submit" class="btn btn-danger">
								Delete
							</button>
						</form>
					</div>
				</div>
			</div>
		</div>

		<!-- RENT A MOVIE -->
		<div id="rentSection" class="d-none">
			@if (@Model.IsAvailable)
			{
				<form asp-controller="MovieRentals"
					  asp-action="RentMovie"
					  asp-route-movieId="@Model.Id"
					  method="post" class="d-inline">
					<span class="badge bg-success me-2">
						<i class="bi bi-check-circle-fill"></i> Available
					</span>

					<button type="submit" class="btn btn-primary">
						<i class="bi bi-cart-plus-fill"></i>
						<span >Rent Now</span>
						<span class="badge bg-warning text-dark">$7.00</span>
					</button>

				</form>
			}
			else
			{
				<span class="badge bg-warning text-dark me-2">
					<i class="bi bi-exclamation-circle"></i> Not Available
				</span>

				<button class="btn btn-secondary" disabled>
					<i class="bi bi-lock-fill"></i> Rented
				</button>
			}
		</div>

		<!-- Owen A MOVIE -->
		<div id="buySection" class="d-none">
			@if (ViewBag.OwnsMovie)
			{
				<span class="badge bg-success me-2">
					<i class="bi bi-check-circle-fill"></i> Owned
				</span>

				<button class="btn btn-secondary" disabled>
					<i class="bi bi-lock-fill"></i> Purchased
				</button>
			}
			else
			{
				<form asp-controller="MoviePurchases"
					  asp-action="BuyMovie"
					  asp-route-movieId="@Model.Id"
					  method="post" class="d-inline">

					<span class="badge bg-success me-2">
						<i class="bi bi-check-circle-fill"></i> Available
					</span>

					<button type="submit" class="btn btn-primary">
						<i class="bi bi-cart-plus-fill"></i> Buy Now
						<span class="badge bg-warning text-dark">$25.00</span>
					</button>
				</form>
			}
		</div>
	</div>
</div>

@section Scripts {
	<!-- JS: TO ENABLE A BUTTON (PURCHASE TYPE) -->
	<script>
		const selectLanguage = document.getElementById('selectLanguage');
		const purchaseOption = document.getElementById('purchaseType');
		const rentSection = document.getElementById('rentSection');
		const buySection = document.getElementById('buySection');

		selectLanguage.addEventListener('change', function () {
			purchaseOption.disabled = this.value === "";
			purchaseOption.value = "";
			rentSection.classList.add('d-none');
			buySection.classList.add('d-none');
		});

		purchaseOption.addEventListener('change', function () {
			rentSection.classList.add('d-none');
			buySection.classList.add('d-none');

			if (this.value === "Rent") {
				rentSection.classList.remove('d-none');
			}
			else if (this.value === "Buy") {
				buySection.classList.remove('d-none');
			}
		});

		// JS: SAVE & UPDATE UI (WATCHLIST)
		document.addEventListener("DOMContentLoaded", function () {

			const form = document.getElementById("watchlistForm");

			if (!form) return;

			form.addEventListener("submit", function (e) {
				e.preventDefault();

				fetch(this.action, {
					method: "POST",
					body: new FormData(this)
				})
				.then(res => {
					if (!res.ok) return;

					// Show modal
					const modal = new bootstrap.Modal(
						document.getElementById("watchlistModal")
					);
					modal.show();

					setTimeout(() => modal.hide(), 2000);

					// Update UI immediately
					document.getElementById("watchlistContainer").innerHTML = `
						<i class="fa-solid fa-bookmark text-secondary me-2 opacity-50 fs-4"
						   title="In Watchlist"
						   aria-label="In Watchlist"></i>
					`;
				});
			});
		});
	</script>
}