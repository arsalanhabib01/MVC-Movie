@model MVC_Movie.Models.Movie

@{
    Layout = "_FullscreenLayout";
    ViewData["Title"] = "Edit Movie";
}

<div class="row justify-content-center">
	<div class="col-lg-8 col-xl-6">

		<div class="card shadow-lg border-0 rounded-4">
			
			<div class="card-body p-4 p-md-4">

				<div class="position-relative mb-4 mt-1">

					<!-- Centered title -->
					<h3 class="fw-bold text-center m-0">
						<i class="fa-regular fa-pen-to-square fs-2 text-warning"></i>
						Edit Movie
					</h3>
					
					<!-- Right aligned close icon -->
					<a class="position-absolute top-50 end-0 translate-middle-y
						btn btn-light p-1 close-icon"
					    asp-action="Details"
					    asp-route-id="@Model.Id">
						<i class="fa fa-times fs-2"></i>
					</a>
				</div>

				<form asp-action="Edit" enctype="multipart/form-data">

					<input type="hidden" asp-for="Id" />
					<input type="hidden" asp-for="UserId" />
					<input type="hidden" asp-for="FileName" />
					<input type="hidden" asp-for="IsAvailable" />
					
					<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

					<div class="mb-3">
						<label asp-for="Title" class="form-label fw-semibold"></label>
						<input asp-for="Title" class="form-control" />
					</div>

					<div class="row mb-3">
						<div class="col-md-4">
							<label asp-for="ReleaseDate" class="form-label fw-semibold"></label>
							<input asp-for="ReleaseDate" class="form-control" type="date" />
						</div>

						<div class="col-md-5">
							<label asp-for="Genre" class="form-label fw-semibold"></label>
							<input asp-for="Genre" class="form-control" />
						</div>
						<div class="col-md-3">
							<label asp-for="Rating" class="form-label fw-semibold"></label>
							<input asp-for="Rating" class="form-control" type="number" step="0.1" />
						</div>
					</div>

					<div class="mb-3">
						<label asp-for="Description" class="form-label fw-semibold"></label>
						<textarea asp-for="Description" class="form-control" rows="3"></textarea>
					</div>

					<div class="row">

						<!-- IMAGE PREVIEW -->
						@if (!string.IsNullOrEmpty(Model.FileName))
						{
							<div id="preview-container" class="col-md-5 mb-4 text-center">
								<label class="form-label fw-semibold d-block">
									Current Poster</label>
								<img id="preview-image" src="~/images/@Model.FileName"
									 class="img-thumbnail shadow-sm"
									 style="max-width:150px;" />
							</div>
						}


						<!-- FILE UPLOAD -->
						<div class="col-md-7 mb-4">
							<label asp-for="FileForm" class="form-label fw-semibold"></label>
							<input asp-for="FileForm" type="file" class="form-control" 
								onchange="previewImage(event)" />
						</div>
					</div>

					<div class="d-flex justify-content-between mt-2">
						<a class="btn btn-outline-secondary px-4"
						   asp-action="Details" asp-route-id="@Model.Id">
							Cancel
						</a>
						<button type="submit" class="btn btn-primary px-4">
							<i class="fa fa-save me-1"></i> 
							Save Changes
						</button>
					</div>

				</form>

			</div>
		</div>
	</div>
</div>



@section Scripts {
    <script>
        function previewImage(event) {
            // Get the file input element and the preview elements
            // from the event target
            // event.target is the file input
            const input = event.target;
            // Get the preview container and image elements
            const previewContainer = document.getElementById("preview-container");
            const previewImage = document.getElementById("preview-image");

            // Check if a file is selected
            // input.files is the FileList object
            // input.files[0] is the first selected file
            if (input.files && input.files[0]) {
                // Create a FileReader to read the file
                const reader = new FileReader();
                // When the file is read, set the preview image source
                // and make the preview container visible
                reader.onload = function(e) {
                    // Set the preview image source to the file data
                    previewImage.src = e.target.result;
                    // Show the preview container
                    // "block" to make it visible"
                    previewContainer.style.display = "block";
                };
                // Read the file as a Data URL (base64)
                reader.readAsDataURL(input.files[0]);
            } else {
                // No file selected, hide the preview container
                // "none" to hide it
                previewContainer.style.display = "none";
                // Clear the preview image source
                previewImage.src = "";
            }
        }
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
