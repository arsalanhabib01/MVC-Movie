@model IEnumerable<MVC_Movie.Models.Coupon>

@{
	ViewData["Title"] = "My Coupons";
}

@if (!Model.Any())
{
	<div class="alert alert-info text-center mt-5">
		No Coupons available.
	</div>
}
else
{
	<div class="container mt-5">
		<div class="row">

			@foreach (var coupon in Model)
			{
				var isExpired = coupon.ExpiryDate < DateTime.Now;
				var isLimitReached = coupon.TimesUsed >= coupon.UsageLimit;

				var cardClass = isExpired
				? "border-dark bg-light text-muted opacity-75"
				: isLimitReached
				? "border-danger bg-light text-muted"
				: "border-success";

				<div class="col-md-3 mb-4 shadow p-2 me-2 @cardClass">
					<div class="card-body d-flex justify-content-between align-items-center">

						<div>
							<h5 class="card-title mb-1">@coupon.Code</h5>

							<p class="mb-1">
								Type:
								@if (coupon.CouponType == CouponType.Rent)
								{
									<span class="badge bg-warning text-dark mb-2">Rent</span>
								}
								else if (coupon.CouponType == CouponType.Purchase)
								{
									<span class="badge bg-success mb-2">Purchase</span>
								}
								else if (coupon.CouponType == CouponType.Birthday)
								{
									<span class="badge bg-primary mb-2">Birthday</span>
								}
							</p>

							<small class="text-muted">
								Expires: @coupon.ExpiryDate.ToShortDateString()
							</small>
						</div>

						<div class="text-end">
							@if (coupon.CouponType == CouponType.Rent)
							{
								<h4 class="text-warning mb-2">
									@coupon.DiscountPercentage.ToString("0")%
								</h4>
							}
							else if (coupon.CouponType == CouponType.Purchase)
							{
								<h4 class="text-success mb-2">
									@coupon.DiscountPercentage.ToString("0")%
								</h4>
							}
							else if (coupon.CouponType == CouponType.Birthday)
							{
								<h4 class="text-primary mb-2">
									@coupon.DiscountPercentage.ToString("0")%
								</h4>
							}

							<span class="badge bg-secondary">
								@coupon.TimesUsed / @coupon.UsageLimit Used
							</span>

							@if (isExpired)
							{
								<div class="mt-2">
									<span class="badge bg-dark">Expired</span>
								</div>
							}
							else if (isLimitReached)
							{
								<div class="mt-2">
									<span class="badge bg-danger">Limit Reached</span>
								</div>
							}

						</div>

					</div>
				</div>
			}

		</div>
	</div>
}