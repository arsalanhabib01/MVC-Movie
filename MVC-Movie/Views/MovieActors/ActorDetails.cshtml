@model MVC_Movie.Models.MovieActor

@{
	Layout = "_FullscreenLayout";
	ViewData["Title"] = "Actor Details";
}

<div class="row bg-white rounded-3 shadow-lg p-4 mt-4">

	<!-- LEFT: IMAGE -->
	<div class="col-md-4 position-relative text-center mb-4 mb-md-0">

		<img src="@Url.Content($"~/Actor/images/{Model.ProfileImage}")"
			 class="img-fluid rounded border"
			 alt="Actor Image"
			 style="height:450px; width:100%; object-fit:cover;" />
	</div>

	<!-- RIGHT: DETAILS -->
	<div class="col-md-8">

		<!-- TOP BAR: Actor Title + Close Button -->
		<div class="d-flex justify-content-between align-items-center mb-4">
			<div class="d-flex align-items-center border-start border-4 border-primary ps-3">
				<div class="bg-light rounded-circle p-2 shadow-sm me-3">
					<i class="fa-solid fa-user-tie text-primary fs-5"></i>
				</div>
				<div>
					<h2 class="fw-bold mb-0 text-uppercase">
						@Model.FullName
					</h2>
					<small class="text-muted">Actor Profile</small>
				</div>
			</div>

			<!-- CLOSE BUTTON -->
			<a class="btn btn-outline-secondary rounded-circle shadow-sm 
			   d-flex align-items-center justify-content-center"
			   style="width:45px; height:45px;"
			   asp-controller="Movies"
			   asp-action="Details"
			   asp-route-id="@Model.MovieId">
				<i class="fa fa-times fs-5"></i>
			</a>
		</div>

		<!-- Actor Info Badges -->
		<div class="d-flex flex-wrap gap-2 mb-4">
			@if (Model.DateOfBirth != null)
			{
				<span class="badge bg-primary text-white p-2">
					<i class="bi bi-calendar-event me-1"></i>
					@Model.DateOfBirth?.ToString("MMM dd, yyyy")
				</span>

				<span class="badge bg-success text-white p-2">
					<i class="fa-solid fa-hourglass-half me-1"></i>
					@{
						var today = DateTime.Today;
						var age = today.Year - Model.DateOfBirth.Value.Year;
						if (Model.DateOfBirth.Value.Date > today.AddYears(-age)) age--;
					}
					@age years
				</span>
			}

			@if (!string.IsNullOrEmpty(Model.Nationality))
			{
				<span class="badge bg-secondary text-white p-2 text-capitalize">
					<i class="fa-solid fa-flag me-1"></i>
					@Model.Nationality
				</span>
			}
		</div>

		<!-- Biography Section -->
		<div class="card shadow-sm border-0 mb-4">
			<div class="card-header bg-light fw-bold text-uppercase">
				<i class="fa-solid fa-pen me-1"></i> Biography
			</div>
			<div class="card-body" style="text-align: justify; line-height:1.6;">
				@if (!string.IsNullOrEmpty(Model.Biography))
				{
					<span>@Model.Biography</span>
				}
				else
				{
					<span class="text-muted fst-italic">Biography not available.</span>
				}
			</div>
		</div>


		@if (User.IsInRole("Administrator"))
		{
			<div class="float-end">
				<a class="btn btn-warning me-1"
				   title="Actor Profile Editing"
				   asp-action="EditActorProfile" asp-route-id="@Model.Id">
					<i class="fa fa-pencil text-white"></i>
				</a>

				<!-- Button trigger modal -->
				<button type="button" title="Delete Record"
						class="btn btn-danger"
						data-bs-toggle="modal"
						data-bs-target="#deleteModal">
					<i class="fa fa-trash"></i>
				</button>
			</div>
		}

		<!-- Deletion Modal-->
		<div class="modal fade" id="deleteModal" tabindex="-1">
			<div class="modal-dialog modal-dialog-centered">
				<div class="modal-content">

					<div class="modal-header">
						<h5 class="modal-title text-muted me-2">
							<i class="fa fa-trash text-danger"></i>
							Confirm Deletion
						</h5>
						<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
					</div>

					<div class="modal-body">
						<i class="fa-solid fa-user-tie me-1"></i>
						Please confirm that you want to delete the Actor
						<span class="text-uppercase fw-bold text-muted">@Model.FullName ? </span>
						Portfolio
					</div>

					<div class="modal-footer">
						<button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
							Cancel
						</button>

						<form asp-action="DeleteActorProfile"
							  asp-route-id="@Model.Id" method="post">
							<button type="submit" class="btn btn-danger">
								Delete
							</button>
						</form>
					</div>
				</div>
			</div>
		</div>

	</div>

</div>

