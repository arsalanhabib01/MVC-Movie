@model MVC_Movie.Models.MovieActor

@{
    Layout = "_FullscreenLayout";
    ViewData["Title"] = "Create Actor Profile";
}

<div class="row justify-content-center">
    <div class="col-lg-8 col-xl-6">

        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-body p-4 p-md-4">

				<div class="d-flex justify-content-between align-items-center mb-4">

					<!-- Movie Title -->
					<h2 class="fw-bold">
						<i class="fa-solid fa-user-tie fs-2 me-2 text-primary"></i>
						Add Portfolio
					</h2>

					<!-- CLOSE BUTTON -->
					<a class="btn btn-outline-secondary rounded-circle shadow-sm
					   d-flex align-items-center justify-content-center"
					   style="width:45px; height:45px;"
					   asp-controller="Movies"
					   asp-action="Index">
					   <i class="fa fa-times fs-5"></i>
					</a>

				</div>

				<form asp-action="AddActorProfile"
					  asp-controller="MovieActors"
					  method="post"
					  enctype="multipart/form-data">

					<input type="hidden" asp-for="Id" />

					<div asp-validation-summary="ModelOnly" class="text-danger"></div>

					<div class="mb-2">
						<label asp-for="MovieId" class="form-label fw-semibold">Select Movie</label>
						<select asp-for="MovieId"
								asp-items="ViewBag.MovieId"
								class="select-form w-100 p-1">
						</select>
					</div>

					<div class="mb-2">
						<label asp-for="FullName" class="form-label fw-semibold">Full Name</label>
						<span class="text-warning">*</span>
						<input asp-for="FullName" class="form-control" required/>
					</div>

					<div class="row mb-2">
						<div class="col-md-6">
							<label asp-for="DateOfBirth" class="form-label fw-semibold">Date Of Birth</label>
							<input asp-for="DateOfBirth" type="date" class="form-control" />
							<span asp-validation-for="DateOfBirth" class="text-danger"></span>
						</div>

						<div class="col-md-6">
							<label asp-for="Nationality" class="form-label fw-semibold"></label>
							<input asp-for="Nationality" class="form-control" />
							<span asp-validation-for="Nationality" class="text-danger"></span>
						</div>
					</div>

					<div class="mb-2">
						<label asp-for="Biography" class="form-label fw-semibold"></label>
						<span class="text-warning">*</span>
						<textarea asp-for="Biography" class="form-control" required></textarea>
					</div>

					<div class="mb-2">
						<label asp-for="ImageFile" class="form-label fw-semibold">Actor Image</label>
						<input asp-for="ImageFile" type="file" class="form-control"
							   onchange="previewImage(event)" />
					</div>

					<div id="preview-container" class="mb-4 text-center" style="display:none;">
						<label class="form-label fw-semibold d-block">Selected Image</label>
						<img id="preview-image"
							 class="img-thumbnail shadow-sm"
							 style="max-width:150px;" />
					</div>

					<div class="form-group d-flex justify-content-between mt-4">
						<a class="btn btn-outline-secondary px-4"
						   asp-controller="Movies"
						   asp-action="Index">
							Cancel
						</a>
						<button type="submit" class="btn btn-primary px-4">
							Save Portfolio
						</button>
					</div>

				</form>
			</div>
		</div>
	</div>
</div>


@section Scripts {
    <script>
        function previewImage(event) {
            // Get the file input element and the preview elements
            // from the event target
            // event.target is the file input
            const input = event.target;
            // Get the preview container and image elements
            const previewContainer = document.getElementById("preview-container");
            const previewImage = document.getElementById("preview-image");

            // Check if a file is selected
            // input.files is the FileList object
            // input.files[0] is the first selected file
            if (input.files && input.files[0]) {
                // Create a FileReader to read the file
                const reader = new FileReader();
                // When the file is read, set the preview image source
                // and make the preview container visible
                reader.onload = function(e) {
                    // Set the preview image source to the file data
                    previewImage.src = e.target.result;
                    // Show the preview container
                    // "block" to make it visible"
                    previewContainer.style.display = "block";
                };
                // Read the file as a Data URL (base64)
                reader.readAsDataURL(input.files[0]);
            } else {
                // No file selected, hide the preview container
                // "none" to hide it
                previewContainer.style.display = "none";
                // Clear the preview image source
                previewImage.src = "";
            }
        }
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
