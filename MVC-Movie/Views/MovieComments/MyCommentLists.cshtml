@model IEnumerable<MVC_Movie.Models.MovieComment>

@if (!Model.Any())
{
	<div class="alert alert-info text-center mt-5">
		No comments yet.
	</div>
}
else
{
	<h3 class="mb-5 mt-4 text-center text-uppercase">
		<i class="fa-regular fa-comments text-secondary me-2"></i>
		Movie Comments
	</h3>

	@foreach (var item in Model)
	{
		<div class="card mt-3">
			<div class="card-body py-2 bg-light">

				<!-- Comment text -->
				<div class="text-capitalize mb-3 fw-bold text-muted">
					<i class="fa-regular fa-comment-dots text-secondary"></i>
					@item.CommentText
				</div>

				<!-- Top row -->
				<div class="d-flex justify-content-between align-items-start mb-2">

					<!-- Left: Movie title + date -->
					<div class="text-muted small fst-italic d-flex gap-2">
						<span>@item.Movie.Title</span>
						<span>•</span>
						@if (item.UpdatedAt != null)
						{
							<span>UpdatedAt: @item.UpdatedAt</span>
						}
						else
						{
							<span>CreatedAt: @item.CreatedAt</span>
						}

					</div>

					<!-- Right: Remove & Update button -->
					<div class="float-end d-flex">

						<form asp-controller="MovieComments"
							  asp-action="DeleteComment"
							  asp-route-Id="@item.Id"
							  method="post">
							<button class="btn btn-danger btn-sm me-2">
								Delete
							</button>
						</form>

						<!-- COMMENT Button trigger modal -->
						<button type="button" title="Edit Comment"
								class="btn btn-warning btn-sm"
								data-bs-toggle="modal"
								data-bs-target="#editModal-@item.Id">
							Update
						</button>

					</div>

					<!-- Comment Modal-->
					<div class="modal fade" id="editModal-@item.Id" tabindex="-1">
						<div class="modal-dialog modal-dialog-centered">
							<div class="modal-content">

								<div class="modal-header">
									<h5 class="modal-title text-muted w-100 text-center">
										Edit Comment
									</h5>
									<button type="button" class="btn-close" 
										data-bs-dismiss="modal"></button>
								</div>

								<div class="modal-body">

									<form asp-action="EditComment"
										  asp-route-id="@item.Id" method="post">

										<input type="hidden" name="Id" value="@item.Id" />
										<input type="hidden" name="UserId" value="@item.UserId" />
										<input type="hidden" name="MovieId" value="@item.MovieId" />
										<input type="hidden" name="CreatedAt" value="@item.CreatedAt" />
										<input type="hidden" name="UpdatedAt" value="@item.UpdatedAt" />

										<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

										<div class="form-group">

											<label>Your Comment</label>
											<textarea name="CommentText"
											  rows="3"
											  class="form-control">@item.CommentText</textarea>

										</div>
										<div class="modal-footer">
											<button type="button" class="btn btn-outline-secondary" 
												data-bs-dismiss="modal">
												Cancel
											</button>
											<button type="submit" class="btn btn-primary">
												Submit
											</button>
										</div>
									</form>
								</div>
							</div>
						</div>
					</div>

				</div>

			</div>
		</div>
	}
}