@model IEnumerable<MVC_Movie.Models.Notification>

@{
	ViewData["Title"] = "My Notifications";
}

<div class="container mt-4">

	@if (!Model.Any())
	{
		<div class="alert alert-info text-center mt-5">
			No notifications available.
		</div>
	}
	else
	{
		<h3 class="mb-5 mt-4 text-center text-uppercase">
			<i class="fa-solid fa-bell text-primary me-2"></i>
			My Notifications
		</h3>

		@foreach (var item in Model)
		{
			<div class="card mb-3 shadow-sm @(item.IsRead ? "bg-light" : "border-primary")">
				<div class="card-body d-flex justify-content-between align-items-center">
					<div>
						<p class="mb-1 @(item.IsRead ? "text-muted" : "fw-bold")"
						   style="white-space: pre-line;">
							@item.Message
						</p>

						<small class="text-muted">
							@item.CreatedAt.ToString("MMM dd, yyyy HH:mm")
						</small>
					</div>

					@if (!item.IsRead)
					{
						<a asp-action="MarkAsRead"
						   asp-route-id="@item.Id"
						   class="btn btn-sm btn-outline-primary">
							Mark as Read
						</a>
					}
				</div>
			</div>
		}
	}
</div>