@model MVC_Movie.Models.UserProfile

@{
    ViewData["Title"] = "My Profile";
}

@* <h3 class="fw-bold mb-5">
    <i class="fa-solid fa-user text-success me-2"></i>
    My Profile
</h3> *@

<div class="card" style="width: 25rem;">
    @if (!string.IsNullOrEmpty(Model.ProfileImage))
    {
        <img src="@Url.Content($"~/profile/{Model.ProfileImage}")" class="card-img-top" alt="Profile Image" />

    }
    else
    {
        <img src="~/profile/default-picture.jpg" class="card-img-top" alt="Default Image" />
    }

    <div class="card-body">
        <h5 class="card-title text-muted">
            <i class="fa-solid fa-id-card me-1 text-secondary"></i>
            @Model.FullName</h5>

        <p class="card-text">
            <strong>Date of Birth:</strong>
            <i class="fa-solid fa-calendar-days me-1 text-secondary"></i>
            @Model.DateOfBirth?.ToShortDateString()
        </p>

        <p class="card-text" style="text-align: justify;">
            <strong>Bio: </strong><i class="fa-solid fa-pen me-1 text-secondary"></i>
            <br />
            @Model.Bio
        </p>

        <p class="card-text text-muted">
            Profile Created: @Model.CreatedAt.ToShortDateString()
        </p>

        <a asp-action="EditMyProfile" asp-route-id="@Model.Id"
            class="btn btn-warning px-4 text-white">
            Edit Profile</a>
    </div>
</div>
